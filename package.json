    "bibliography",
    "citations",
    "bibtex",
    "apa",
    "mla"
  ],
  "author": "Proximify",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uniweb/scholar.git"
  },
  "homepage": "https://github.com/uniweb/scholar#readme",
  "bugs": {
    "url": "https://github.com/uniweb/scholar/issues"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "katex": "^0.16.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
