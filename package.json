{
  "name": "@uniweb/scholar",
  "version": "0.2.0",
  "description": "Academic content utilities for Uniweb - math rendering, bibliographic references, and inline citations",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./math": "./src/math/index.js",
    "./bibliography": "./src/bibliography/index.js",
    "./citations": "./src/citations/index.js",
    "./components": "./src/components/index.js"
  },
  "files": [
    "src"
  ],
  "sideEffects": false,
  "keywords": [
    "uniweb",
    "scholar",
    "academic",
    "math",
    "katex",
